#!/usr/bin/env bash

# Sets volume/toggle mute and displays a dunst notification.
SINK="@DEFAULT_AUDIO_SINK@"

case "$1" in
more)
  wpctl set-volume -l 1 "$SINK" 5%+
  ;;
less)
  wpctl set-volume "$SINK" 5%-
  ;;
toggle-mute)
  wpctl set-mute "$SINK" toggle
  ;;
*)
  echo "Usage: $(basename "$0") [more|less|toggle-mute]" >&2
  exit 1
  ;;
esac

icon=""
raw_volume=$(wpctl get-volume "$SINK")
volume=$(echo "$raw_volume" | awk '{print $2 * 100}')

if echo "$raw_volume" | grep -qi "muted"; then
  icon=""
fi

notify-send -h int:value:"$volume" -h boolean:transient:true "" "$icon"
