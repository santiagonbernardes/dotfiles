#!/usr/bin/env python3

import os
import subprocess
import sys
from pathlib import Path

BW_ENV_VAR: str = "BW_SESSION"
REPOSITORY: str = "https://github.com/santiagonbernardes/ostests.git"
DESTINATION: Path = Path.home().joinpath(".local/share/management")
BRANCH: str = "ansible"


def _install_ansible() -> None:
    subprocess.run(
        [
            "/usr/bin/ansible-playbook",
            "main.yml",
            "-K",
        ],
        check=True,
        cwd=str((DESTINATION / "system")),
    )


def _install_dotfiles() -> None:
    subprocess.run(
        ["/usr/bin/chezmoi", "init", "--apply", "--source", str(DESTINATION)],
        check=True,
    )


def _ensure_packages(packages: list[str]) -> None:
    subprocess.run(
        ["sudo", "pacman", "-Sy", "--needed", "--noconfirm", "--quiet", *packages],
        check=True,
    )


def _ensure_environment() -> None:
    bw_session: str | None = os.getenv(BW_ENV_VAR)

    if bw_session:
        return

    result = subprocess.run(
        ["/usr/bin/bw", "login", "--raw"],
        check=False,
        text=True,
        stdout=subprocess.PIPE,
    )

    if result.returncode != 0:
        result = subprocess.run(
            ["/usr/bin/bw", "unlock", "--raw"],
            check=True,
            text=True,
            stdout=subprocess.PIPE,
        )

    os.environ[BW_ENV_VAR] = result.stdout.strip()


def _clone_repo() -> None:
    git: str = "/usr/bin/git"
    if not DESTINATION.exists():
        subprocess.run(
            [git, "clone", REPOSITORY, str(DESTINATION)],
            check=True,
        )

    subprocess.run(
        [git, "switch", BRANCH],
        cwd=str(DESTINATION),
        check=True,
    )


if __name__ == "__main__":
    try:
        _ensure_packages(["bitwarden-cli", "ansible", "git"])
        _ensure_environment()
        _clone_repo()
        _install_ansible()
        _ensure_packages(["bitwarden-cli", "chezmoi"])
        _install_dotfiles()
    except subprocess.CalledProcessError as e:
        print(
            f"Command failed with exit code {e.returncode} and error {e.stderr}",
            file=sys.stderr,
        )
        sys.exit(e.returncode)
