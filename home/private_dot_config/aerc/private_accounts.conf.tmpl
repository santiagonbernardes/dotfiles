[Main]
source-cred-cmd = bw get password aerc/gmail --raw
outgoing-cred-cmd = bw get password aerc/gmail --raw
source        = imaps://{{- .email -}}@imap.gmail.com:993
outgoing      = smtp://{{- .email -}}@smtp.gmail.com:587
default       = INBOX
from          = {{ .name }} <{{ .email }}>
cache-headers = true
