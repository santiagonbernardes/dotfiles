#!/usr/bin/env bash

current=$(powerprofilesctl get)
profiles=$(powerprofilesctl list | grep -E '^(\*| ) [a-z]' | tr -d '* :')
menu_options=""

for P in $profiles; do
  if [ "$P" = "$current" ]; then
    menu_options+="<span color='#50FA7B'><b>$P</b></span>\n"
  else
    menu_options+="$P\n"
  fi
done

selected=$(echo -e "${menu_options%\\n}" | rofi -dmenu -i -markup-rows -p "Power Profile")

if [ -n "$selected" ]; then
  clean_selected=$(echo "$selected" | sed 's/<[^>]*>//g')
  powerprofilesctl set "$clean_selected"
fi
