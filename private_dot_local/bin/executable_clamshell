#!/usr/bin/env bash

# Inpired by: https://github.com/Kore29/hyprland-clamshell/blob/6b7e2c3f2aa6368c119fa057566dbb3eb01bdc96/clamshell.sh

internal="${INTERNAL_DISPLAY:-eDP-1}"

notify_user() {
  # Change '-u low' to '-u normal' if you want popups to stay longer
  notify-send -u low "$1" "$2"
}

mode_close() {
  local monitors_count
  monitors_count=$(hyprctl monitors all -j | jq length)

  if [[ $monitors_count -gt 1 ]]; then
    hyprctl eval "hl.monitor({ output = \"$internal\", disabled = true })"
  fi
}

mode_open() {
  hyprctl eval "hl.monitor({ output = \"$internal\", mode = \"preferred\", position = \"auto\", scale = 2, disabled = false })"
}

case "$1" in
close)
  mode_close
  notify_user "Clamshell Mode" "External monitor active. Laptop screen disabled."
  ;;
open)
  mode_open
  notify_user "Laptop Mode" "Laptop screen enabled."
  ;;
check)
  if grep -q "open" /proc/acpi/button/lid/*/state; then
    mode_open
  else
    mode_close
  fi
  ;;
*)
  echo "Usage: $0 [open|close|check]"
  exit 1
  ;;
esac
